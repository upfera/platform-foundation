{
  "problemMatcher": [
    {
      "owner": "ansible-fatal",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^fatal: \\[(.+)\\]: FAILED! => (.+)$",
          "file": 1,
          "message": 2
        }
      ]
    },
    {
      "owner": "ansible-error",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^Error: (.+)$",
          "message": 1
        }
      ]
    }
  ]
}
