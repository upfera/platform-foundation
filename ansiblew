#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

VENV_DIR=".venv"
ANSIBLE_VERSION="2.20.4"

echo "==> [1/4] Checking Python venv..."

if [ ! -d "$VENV_DIR" ]; then
  python3 -m venv "$VENV_DIR"
fi

source "$VENV_DIR/bin/activate"

echo "==> [2/4] Upgrading pip + installing Ansible..."

pip install --upgrade pip
pip install "ansible-core==${ANSIBLE_VERSION}"

echo "==> [3/4] Installing required collections..."

export ANSIBLE_CONFIG="$ROOT/ansible/ansible.cfg"
ansible-galaxy collection install community.general ansible.posix -p ./collections

echo "==> [4/4] Running ansible-playbook: $*"

exec ansible-playbook "$@"